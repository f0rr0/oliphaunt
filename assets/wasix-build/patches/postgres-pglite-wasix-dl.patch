--- /dev/null
+++ b/src/makefiles/Makefile.wasix-dl
@@ -0,0 +1,14 @@
+# Use unversioned shared objects for WebAssembly side modules.
+rpath =
+AROPT = crs
+
+# Rule for building a shared library from a single .o file.
+%.so: %.o
+	$(CC) $(CFLAGS) $< $(LDFLAGS) $(LDFLAGS_SL) -shared -o $@
+
+# WASIX side modules install import lists under the same layout contract that
+# PGlite's dynamic loader consumes, without reusing Emscripten-named variables.
+wasm_dl_include_dir := $(pkgincludedir)/wasix-dl
+wasm_dl_base_dir := $(wasm_dl_include_dir)/base
+wasm_dl_imports_dir := $(wasm_dl_base_dir)/imports
+wasm_dl_extension_dir := $(wasm_dl_include_dir)/extension
