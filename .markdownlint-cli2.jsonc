{
  "globs": [
    "README.md",
    "docs/**/*.md",
    "src/**/README.md",
    "src/sdks/react-native/examples/expo/README.md",
    "src/bindings/wasix-rust/examples/tauri-sqlx-vanilla/README.md"
  ],
