{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "lib/typescript",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["lib", "node_modules"]
}
