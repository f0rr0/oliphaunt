  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "executableFiles": [
      "./bin/oliphaunt-broker.exe"
    ]
  },
  "files": [
    "bin",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json"
  }
}
